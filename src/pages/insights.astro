---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegacyNavbar from '../components/LegacyNavbar.astro';
import FooterLegacy from '../components/FooterLegacy.astro';
import { getCollection } from 'astro:content';

// Fetch published blog posts, newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// Group by cluster for the secondary view
const clusters = [
  'A. Tax Code Decoder',
  'B. Take-Home by Role',
  'C. Take-Home by Hourly Rate',
  'D. Shift Patterns',
  'E. Seasonal & Timely',
  'F. Freelance & Commission',
] as const;
---
<BaseLayout
  title="Insights — UK take-home pay, tax codes, and payroll explained | NetPay UK"
  description="Practical guides on UK take-home pay, tax codes, NI, shift work, and freelance income — written for hourly, shift, and variable-income workers."
  ogDescription="Practical guides on UK take-home pay, tax codes, NI, shift work, and freelance income."
  wfPageId="699df2c3ff7815c5f95aec46"
>
  <LegacyNavbar currentPage="insights" />

  <!-- HERO -->
  <div class="hero-section">
    <div class="container no-padding-bottom">
      <div style="padding-top: 80px; padding-bottom: 40px; max-width: 760px;">
        <h1 class="secondary-page-title" style="font-size: 56px; line-height: 1.1; margin-bottom: 24px;">
          <span class="text-gradient-colored">Insights</span>
        </h1>
        <p style="font-size: 22px; line-height: 1.5; opacity: 0.85;">
          Plain-English guides on UK take-home pay, tax codes, National Insurance, shift work, and what your payslip actually means. Written by the team at NetPay UK.
        </p>
      </div>
    </div>
  </div>

  {posts.length === 0 && (
    <div class="container" style="padding-top: 40px; padding-bottom: 80px;">
      <div style="max-width: 720px; margin: 0 auto; text-align: center; padding: 60px 24px; background: rgba(255,255,255,0.04); border-radius: 16px; border: 1px solid rgba(255,255,255,0.08);">
        <h2 style="font-size: 28px; margin-bottom: 16px;">First posts coming this week</h2>
        <p style="font-size: 18px; line-height: 1.6; opacity: 0.85;">
          We're publishing a new guide every day from 22 May 2026. In the meantime, you can download the NetPay app and start tracking your take-home pay today.
        </p>
        <div style="margin-top: 24px; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
          <a href="https://apps.apple.com/gb/app/netpay-uk-salary-tracker/id6757113332" target="_blank" rel="noopener noreferrer" class="button w-button">Download for iOS</a>
          <a href="https://play.google.com/store/apps/details?id=io.bluka.uknetpay" target="_blank" rel="noopener noreferrer" class="button w-button">Download for Android</a>
        </div>
      </div>
    </div>
  )}

  {posts.length > 0 && (
    <div class="container" style="padding-top: 20px; padding-bottom: 80px;">
      <div style="max-width: 880px; margin: 0 auto;">
        <!-- Latest posts (newest first) -->
        <h2 class="text-gradient-light" style="font-size: 28px; margin-bottom: 24px;">Latest</h2>
        <ul style="list-style: none; padding: 0; margin: 0 0 60px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
          {posts.slice(0, 12).map(post => (
            <li>
              <a href={`/insights/${post.slug}/`} style="display: block; padding: 24px; background: rgba(255,255,255,0.04); border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); color: inherit; text-decoration: none; height: 100%;">
                <div style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.6; margin-bottom: 8px;">
                  {post.data.cluster.replace(/^[A-F]\. /, '')}
                </div>
                <div style="font-size: 18px; font-weight: 600; line-height: 1.3; margin-bottom: 12px;">{post.data.title}</div>
                <div style="font-size: 14px; line-height: 1.5; opacity: 0.75; margin-bottom: 16px;">{post.data.description}</div>
                <div style="font-size: 12px; opacity: 0.5;">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                </div>
              </a>
            </li>
          ))}
        </ul>

        <!-- By cluster -->
        <h2 class="text-gradient-light" style="font-size: 28px; margin-bottom: 24px;">By topic</h2>
        {clusters.map(cluster => {
          const clusterPosts = posts.filter(p => p.data.cluster === cluster);
          if (clusterPosts.length === 0) return null;
          return (
            <section style="margin-bottom: 40px;">
              <h3 style="font-size: 20px; font-weight: 600; margin-bottom: 12px; opacity: 0.9;">
                {cluster.replace(/^[A-F]\. /, '')}
              </h3>
              <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
                {clusterPosts.map(post => (
                  <li>
                    <a href={`/insights/${post.slug}/`} style="display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 12px 0; color: inherit; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.05);">
                      <span style="font-size: 16px;">{post.data.title}</span>
                      <span style="font-size: 13px; opacity: 0.5; white-space: nowrap;">
                        {post.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>
    </div>
  )}

  <FooterLegacy currentPage="insights" wfPageId="699df2c3ff7815c5f95aec46" />
</BaseLayout>
