---
import BaseLayout from '../layouts/BaseLayout.astro';
import Organization from '../components/schema/Organization.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Delete Account: NetPay"
  description="Request deletion of your NetPay account data. Submit your email and we will process your request within 2-3 business days."
>
  <Organization slot="schema" />
  <Navbar activePage="" />

  <!-- Hero -->
  <div class="hero-section">
    <div class="container no-padding-bottom">
      <div class="secondary-page-holders">
        <div class="text-hidden">
          <div class="hero-text-1">
            <h1 class="secondary-page-title"><span class="text-gradient-light">Delete Account &amp; Data</span></h1>
          </div>
        </div>
        <div class="small-content">
          <p class="white-50pct">Request deletion of your personal data from our systems in line with UK GDPR.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="section">
    <div class="container">
      <div class="delete-layout">
        <div>
          <h2 style="color: #fff; margin-bottom: 24px;">What gets deleted</h2>
          <ul style="color: rgba(255,255,255,0.7); line-height: 1.8;">
            <li>Your email address from our waitlist and mailing lists</li>
            <li>Any support correspondence we have on file</li>
            <li>Analytics data that could identify you personally</li>
          </ul>
          <p style="color: rgba(255,255,255,0.55); font-size: 14px; margin-top: 24px;">
            Note: Your work hours, rates, and financial data entered in the app are stored locally on your device only. 
            Simply deleting the app removes this data.
          </p>
        </div>
        
        <div class="delete-card">
          <h3 style="color: #fff; margin-bottom: 16px;">Request Deletion</h3>
          <p style="color: rgba(255,255,255,0.65); margin-bottom: 24px;">
            Enter the email address you used with NetPay below, and we'll process your deletion request within 30 days as required by UK GDPR.
          </p>
          
          <form netlify netlify-honeypot="bot-field" hidden>
            <input name="bot-field">
          </form>
          
          <form name="delete-request" method="POST" data-netlify="true">
            <div style="margin-bottom: 16px;">
              <input 
                type="email" 
                name="email" 
                placeholder="Your email address" 
                required
                style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff; font-family: 'Archivo', sans-serif;"
              />
            </div>
            <button 
              type="submit"
              class="button w-button"
              style="width: 100%;"
            >
              Request Deletion
            </button>
          </form>
          
          <p style="color: rgba(255,255,255,0.35); font-size: 12px; margin-top: 16px;">
            We'll email you to confirm the request and notify you when it's complete.
          </p>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  .delete-layout {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 28px;
    align-items: start;
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 0 96px;
  }
  .delete-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 32px;
  }
  @media (max-width: 767px) {
    .delete-layout { grid-template-columns: 1fr; }
  }
</style>