---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketingNavbar from '../components/MarketingNavbar.astro';
import FooterMarketingMinimal from '../components/FooterMarketingMinimal.astro';
---
<BaseLayout
  title="Freelancers &amp; Sales Waitlists | NetPay"
  description="NetPay UK for shift workers is on Google Play. Join the waitlist for upcoming Freelancers or Sales apps and get launch updates by email."
  ogDescription="NetPay UK is on Google Play. Waitlist signup for upcoming Freelancers and Sales apps."
  wfPageId="699df2c3ff7815c5f95aecab"
>
  <style slot="head-extras">
    .beta-layout { max-width: 980px; margin: 0 auto; padding: 48px 0 96px; }
    .beta-intro-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 32px; margin-bottom: 28px; }
    .beta-intro-card h2 { font-family: 'Schibsted Grotesk', sans-serif; font-size: 28px; line-height: 1.2; font-weight: 600; color: #fff; margin: 0 0 14px; }
    .beta-intro-card p { margin: 0 0 16px; color: rgba(255,255,255,0.62); font-family: 'Archivo', sans-serif; font-size: 15px; line-height: 1.75; }
    .beta-hero-link { color: #3de85d; font-weight: 600; text-decoration: none; }
    .beta-hero-link:hover { text-decoration: underline; }
    .beta-pill { display: inline-block; margin-bottom: 14px; padding: 6px 12px; border-radius: 999px; border: 1px solid rgba(61,232,93,0.35); background: rgba(61,232,93,0.12); color: #3de85d; font-family: 'Archivo', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.4px; text-transform: uppercase; }
    .steps-list { list-style: none; padding: 0; margin: 18px 0 0; }
    .steps-list li { margin: 0 0 10px; color: rgba(255,255,255,0.7); font-family: 'Archivo', sans-serif; font-size: 15px; line-height: 1.65; }
    .steps-list li strong { color: #fff; }
    .beta-waitlists-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .beta-form-holder { background: rgba(11,14,20,0.5); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 28px; }
    .form-app-title { font-family: 'Schibsted Grotesk', sans-serif; font-size: 24px; line-height: 1.2; font-weight: 600; color: #fff; margin: 0 0 8px; }
    .form-app-copy { margin: 0 0 18px; color: rgba(255,255,255,0.62); font-family: 'Archivo', sans-serif; font-size: 14px; line-height: 1.7; }
    .beta-form-label { display: block; margin-bottom: 8px; color: rgba(255,255,255,0.9); font-family: 'Archivo', sans-serif; font-size: 14px; font-weight: 500; }
    .beta-input, .beta-select { width: 100%; border: 1px solid rgba(255,255,255,0.16); background: rgba(255,255,255,0.03); color: #fff; border-radius: 12px; padding: 12px 14px; margin-bottom: 18px; font-family: 'Archivo', sans-serif; font-size: 14px; line-height: 1.4; }
    .beta-input:focus, .beta-select:focus { border-color: rgba(61,232,93,0.6); outline: none; box-shadow: 0 0 0 3px rgba(61,232,93,0.12); }
    .beta-select option { color: #111; background: #fff; }
    .consent-wrap { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 16px; }
    .consent-wrap input { margin-top: 4px; }
    .consent-wrap label { margin: 0; color: rgba(255,255,255,0.72); font-family: 'Archivo', sans-serif; font-size: 13px; line-height: 1.6; }
    .consent-wrap a { color: #3de85d; text-decoration: none; }
    .beta-button { width: 100%; border: none; border-radius: 12px; background: linear-gradient(90deg, #3de85d 0%, #03f6f4 100%); color: #06131b; font-family: 'Archivo', sans-serif; font-size: 15px; font-weight: 700; padding: 13px 16px; cursor: pointer; transition: transform 180ms ease, box-shadow 180ms ease; }
    .beta-button:hover { transform: translateY(-1px); box-shadow: 0 10px 22px rgba(3,246,244,0.18); }
    .beta-help { margin-top: 12px; color: rgba(255,255,255,0.5); font-family: 'Archivo', sans-serif; font-size: 13px; line-height: 1.6; text-align: center; }
    .beta-help a { color: #3de85d; text-decoration: none; }
    .success-notice { display: none; margin-bottom: 18px; padding: 12px 14px; border-radius: 10px; border: 1px solid rgba(61,232,93,0.35); background: rgba(61,232,93,0.12); color: #bffcc8; font-family: 'Archivo', sans-serif; font-size: 14px; line-height: 1.6; }
    .hidden-field { display: none; }
    @media (max-width: 991px) { .beta-waitlists-grid { grid-template-columns: 1fr; } }
  </style>

  <MarketingNavbar />

  <div class="hero-section">
    <div class="container no-padding-bottom">
      <div class="secondary-page-holders">
        <div class="text-hidden">
          <div class="hero-text-1">
            <h1 class="secondary-page-title"><span class="text-gradient-light">Join the Waitlist</span></h1>
          </div>
        </div>
        <div class="small-content">
          <p class="white-50pct"><strong>NetPay UK</strong> for shift workers is on <a href="https://play.google.com/store/apps/details?id=io.bluka.uknetpay" class="beta-hero-link" target="_blank" rel="noopener noreferrer">Google Play</a>. Freelancers and Sales are two separate upcoming apps—pick the waitlist below and leave your name and email for launch updates.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="beta-layout">
        <div class="beta-intro-card">
          <div class="beta-pill">Coming soon waitlists</div>
          <h2>How this works</h2>
          <p>Each app has its own form, so your details go to the right waitlist.</p>
          <p>Submit your name and email for Freelancers or Sales, and we will only send updates for the app you selected.</p>
          <ul class="steps-list">
            <li><strong>Step 1:</strong> Add your name and email.</li>
            <li><strong>Step 2:</strong> We add you to that app waitlist.</li>
            <li><strong>Step 3:</strong> We email launch and early access updates.</li>
          </ul>
        </div>

        <div class="beta-waitlists-grid">
          <div class="beta-form-holder" id="freelancers-waitlist">
            <h3 class="form-app-title">Freelancers</h3>
            <p class="form-app-copy">Join the NetPay Freelancers waitlist.</p>
            <div id="success-notice-freelancers" class="success-notice">You are on the Freelancers waitlist. We will email you when this app is ready.</div>
            <form name="freelancers-waitlist-signup" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/android-beta?success=freelancers">
              <input type="hidden" name="form-name" value="freelancers-waitlist-signup">
              <input type="hidden" name="app_interest" value="freelancers">
              <p class="hidden-field">
                <label>Do not fill this out if you are human: <input name="bot-field"></label>
              </p>

              <label for="freelancers-email" class="beta-form-label">Email address</label>
              <input id="freelancers-email" class="beta-input" type="email" name="email" placeholder="you@example.com" autocomplete="email" required>

              <label for="freelancers-name" class="beta-form-label">Name</label>
              <input id="freelancers-name" class="beta-input" type="text" name="name" placeholder="Your name" autocomplete="name" required>

              <div class="consent-wrap">
                <input id="freelancers-consent" type="checkbox" name="email_updates_consent" value="yes" required>
                <label for="freelancers-consent">I agree to receive Freelancers waitlist emails from NetPay. See our <a href="/privacy">Privacy Policy</a>.</label>
              </div>

              <button type="submit" class="beta-button">Join Freelancers Waitlist</button>
            </form>
          </div>

          <div class="beta-form-holder" id="sales-waitlist">
            <h3 class="form-app-title">Sales</h3>
            <p class="form-app-copy">Join the NetPay Sales waitlist.</p>
            <div id="success-notice-sales" class="success-notice">You are on the Sales waitlist. We will email you when this app is ready.</div>
            <form name="sales-waitlist-signup" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/android-beta?success=sales">
              <input type="hidden" name="form-name" value="sales-waitlist-signup">
              <input type="hidden" name="app_interest" value="sales">
              <p class="hidden-field">
                <label>Do not fill this out if you are human: <input name="bot-field"></label>
              </p>

              <label for="sales-email" class="beta-form-label">Email address</label>
              <input id="sales-email" class="beta-input" type="email" name="email" placeholder="you@example.com" autocomplete="email" required>

              <label for="sales-name" class="beta-form-label">Name</label>
              <input id="sales-name" class="beta-input" type="text" name="name" placeholder="Your name" autocomplete="name" required>

              <div class="consent-wrap">
                <input id="sales-consent" type="checkbox" name="email_updates_consent" value="yes" required>
                <label for="sales-consent">I agree to receive Sales waitlist emails from NetPay. See our <a href="/privacy">Privacy Policy</a>.</label>
              </div>

              <button type="submit" class="beta-button">Join Sales Waitlist</button>
            </form>
          </div>
        </div>
        <p class="beta-help">Prefer email? Send "Freelancers Waitlist" or "Sales Waitlist" to <a href="mailto:info@bluka.io?subject=Waitlist%20Signup">info@bluka.io</a>.</p>
      </div>
    </div>
  </div>

  <FooterMarketingMinimal supportSecondLink="delete-account" />

  <div class="preloader">
    <div class="preloader-bg"></div>
    <img src="/images/netpaylogo.svg" alt="NetPay" style="height:36px;display:block;">
  </div>

  <script is:inline>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var successValue = params.get("success");
    if (successValue === "freelancers") {
      var freelancersSuccessNotice = document.getElementById("success-notice-freelancers");
      if (freelancersSuccessNotice) {
        freelancersSuccessNotice.style.display = "block";
      }
    }
    if (successValue === "sales") {
      var salesSuccessNotice = document.getElementById("success-notice-sales");
      if (salesSuccessNotice) {
        salesSuccessNotice.style.display = "block";
      }
    }
    var appValue = params.get("app");
    if (appValue === "freelancers") {
      var freelancersSection = document.getElementById("freelancers-waitlist");
      if (freelancersSection) {
        freelancersSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
    if (appValue === "sales") {
      var salesSection = document.getElementById("sales-waitlist");
      if (salesSection) {
        salesSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
  })();
  </script>
</BaseLayout>
