            <div class="link-block-underline"></div>
          </a>
        </div>
        <div class="fade-in-move-on-scroll">
          <a href="https://apps.apple.com/gb/app/netpay-uk-salary-tracker/id6757113332" target="_blank" rel="noopener noreferrer" class="footer-link w-inline-block">
            <div>App Store Listing</div>
            <div class="link-block-underline"></div>
          </a>
        </div>
      </div>
    </div>
    <div data-w-id="eb050d0c-cd20-6fbc-5d31-0eaf0a144c87" class="made-by-section">
      <div class="copyright-text">© 2026 <a href="https://bluka.io" target="_blank" rel="noopener noreferrer" class="copyright-link">Bluka Labs</a>. All rights reserved.</div>
      <div class="copyright-text">Built with ❤️ for UK workers</div>
    </div>
  </div>
  <div class="footer-gradient-bg-holder">
    <div class="footer-gradient-background"></div><img src="/images/CircleBg_1CircleBg.webp" loading="lazy" data-w-id="c69740f0-85fd-3be9-0eb9-3cdc217038eb" sizes="100vw" alt="" srcset="/images/CircleBg_1-p-500.png 500w, /images/CircleBg_1-p-800.png 800w, /images/CircleBg_1-p-1080.png 1080w, /images/CircleBg_1CircleBg.webp 1092w" class="footer-cricle-bg">
  </div>
  <div class="footer-name-infinit">
    <div class="footer-name-holder">
      <div class="footer-name _1">download</div>
      <div class="footer-name _2">download</div>
      <div class="footer-name _3">download</div>
    </div>
    <div class="footer-download-buttons">
      <a href="https://apps.apple.com/gb/app/netpay-uk-salary-tracker/id6757113332" target="_blank" rel="noopener noreferrer" class="button download-button w-inline-block">
        <div>iOS</div><img src="/images/download.svg" loading="lazy" alt="" class="download-icon">
      </a>
      <a href="https://play.google.com/store/apps/details?id=io.bluka.uknetpay" target="_blank" rel="noopener noreferrer" class="button download-button w-inline-block">
        <div>Android</div><img src="/images/download.svg" loading="lazy" alt="" class="download-icon">
      </a>
