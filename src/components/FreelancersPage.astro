---
// Shared body markup for features.astro and freelancers.astro.
// In production, features.html IS the freelancers page (titled "NetPay for
// Freelancers"). freelancers.html is a runtime JS proxy that fetches and
// rewrites features.html. The Astro migration replaces that proxy by having
// both routes render identical content statically. See memory:
// project-freelancers-proxy.
---
<style is:global>
  .netpay-brand-text {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    background: linear-gradient(90deg, #fff 0%, #a0fbcd 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.5px;
  }
  .coming-soon-badge {
    display: inline-block;
    align-self: flex-start;
    background: rgba(106, 84, 255, 0.2);
    border: 1px solid rgba(106, 84, 255, 0.4);
    color: #a89eff;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    margin-bottom: 16px;
  }
  .hero-waitlist-form {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    flex-wrap: wrap;
    align-items: center;
  }
  .hero-waitlist-form input[type="email"] {
    flex: 1;
    min-width: 220px;
    padding: 12px 18px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #fff;
    font-size: 15px;
    outline: none;
    font-family: 'Archivo', sans-serif;
  }
  .hero-waitlist-form input[type="email"]::placeholder { color: rgba(255,255,255,0.35); }
  .hero-waitlist-form button {
    padding: 12px 24px;
    background: linear-gradient(135deg, #3de85d 0%, #03f6f4 100%);
    color: #0f0f11;
    font-weight: 700;
    font-size: 14px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Archivo', sans-serif;
    white-space: nowrap;
  }
  .hero-waitlist-form button:disabled { opacity: 0.7; cursor: default; }
  .waitlist-note { font-size: 12px; color: rgba(255,255,255,0.3); margin-top: 8px; }
</style>

<!-- Hero -->
<div data-w-id="af76c436-029f-9383-fd05-b7b4a0b8bbf8" class="hero-section">
  <div class="container no-padding-bottom">
    <div class="secondary-page-holders">
      <div class="text-hidden">
        <div style="-webkit-transform:translate3d(0, 110%, 0) scale3d(1, 1, 1) rotateX(27deg) rotateY(0) rotateZ(0) skew(0, 0);-moz-transform:translate3d(0, 110%, 0) scale3d(1, 1, 1) rotateX(27deg) rotateY(0) rotateZ(0) skew(0, 0);-ms-transform:translate3d(0, 110%, 0) scale3d(1, 1, 1) rotateX(27deg) rotateY(0) rotateZ(0) skew(0, 0);transform:translate3d(0, 110%, 0) scale3d(1, 1, 1) rotateX(27deg) rotateY(0) rotateZ(0) skew(0, 0);transform-style:preserve-3d" class="hero-text-1">
          <span class="coming-soon-badge">Coming Soon</span>
          <h1 class="secondary-page-title"><span class="text-gradient-light">Know your take-home.</span><br><span class="text-gradient-colored">Even when your income isn't.</span></h1>
        </div>
      </div>
      <div style="opacity:0" class="hero-description">Freelancing means variable income, unpredictable tax bills, and invoices to chase. NetPay for Freelancers tracks what you earn, estimates what HMRC will want, and helps you stay on top of it all.</div>
      <div class="hero-buttons-holder" style="justify-content:center;">
        <a href="/android-beta?app=freelancers" class="button w-button">Join the waitlist</a>
      </div>
    </div>
    <div class="secondary-hero-image-holder no-bottom-padding">
      <div class="secondary-hero-gradient"></div>
      <div data-w-id="21e64914-b34a-5588-9a1e-ba53b2254b45" class="secondary-image-holder">
        <div class="features-hero-holder _1">
          <div class="card-image-iphone"><img src="/images/Apple-iPhone-12-Pro-Silver-1.svg" loading="lazy" alt="iPhone" class="iphone">
            <div class="ios-app-holder"><img src="/images/netpay-hero.png" loading="lazy" alt="NetPay freelancer income view" class="ios-app" style="object-fit:cover;"></div>
          </div>
        </div>
        <div class="features-hero-holder _2">
          <div class="card-image-iphone"><img src="/images/Apple-iPhone-12-Pro-Silver-1.svg" loading="lazy" alt="iPhone" class="iphone">
            <div class="ios-app-holder"><img src="/images/netpay-day-view.png" loading="lazy" alt="NetPay day view" class="ios-app" style="object-fit:cover;"></div>
          </div>
        </div>
        <div class="features-hero-holder _3">
          <div class="card-image-iphone"><img src="/images/Apple-iPhone-12-Pro-Silver-1.svg" loading="lazy" alt="iPhone" class="iphone">
            <div class="ios-app-holder"><img src="/images/netpay-log-hours.png" loading="lazy" alt="NetPay log hours" class="ios-app" style="object-fit:cover;"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="features-image-gradient"></div>
</div>

