---
export interface Props {
  currentPage?: 'home' | 'freelancers' | 'sales' | 'insights';
}
const { currentPage } = Astro.props;

const homeCurrent = currentPage === 'home';
const freelancersCurrent = currentPage === 'freelancers';
const salesCurrent = currentPage === 'sales';
const insightsCurrent = currentPage === 'insights';
---
<div data-animation="default" class="navbar w-nav" data-easing2="ease" data-easing="ease" data-collapse="medium" role="banner" data-no-scroll="1" data-duration="500" data-doc-height="1">
  <div class="container nav-container">
    <div class="nav-menu-container">
      <a href="/" {...(homeCurrent ? { 'aria-current': 'page' } : {})} class={`brand-link w-nav-brand${homeCurrent ? ' w--current' : ''}`}>
        <img src="/images/netpaylogo.svg" alt="NetPay" style="height:26px;display:block;">
      </a>
      <nav role="navigation" class="nav-menu w-nav-menu">
        <div class="nav-menu-list-items">
          <div class="nav-link-holder">
            <a href="/" {...(homeCurrent ? { 'aria-current': 'page' } : {})} class={`nav-link w-inline-block${homeCurrent ? ' w--current' : ''}`}>
              <div>Shift Workers</div>
              <div class="link-background"></div>
            </a>
          </div>
          <div class="nav-link-holder">
            <a href="/freelancers" {...(freelancersCurrent ? { 'aria-current': 'page' } : {})} class={`nav-link w-inline-block${freelancersCurrent ? ' w--current' : ''}`}>
              <div>Freelancers</div>
              <div class="link-background"></div>
            </a>
          </div>
          <div class="nav-link-holder">
            <a href="/sales" {...(salesCurrent ? { 'aria-current': 'page' } : {})} class={`nav-link w-inline-block${salesCurrent ? ' w--current' : ''}`}>
              <div>Sales</div>
              <div class="link-background"></div>
            </a>
          </div>
          <div class="nav-link-holder">
            <a href="/insights" {...(insightsCurrent ? { 'aria-current': 'page' } : {})} class={`nav-link w-inline-block${insightsCurrent ? ' w--current' : ''}`}>
              <div>Insights</div>
              <div class="link-background"></div>
            </a>
          </div>
        </div>
        <div class="nav-last-button-holder">
          <div class="nav-link-holder">
            <a href="https://apps.apple.com/gb/app/netpay-uk-salary-tracker/id6757113332" target="_blank" rel="noopener noreferrer" class="nav-link w-inline-block">
              <div class="nav-text-gradient">Download App</div>
              <div class="link-background white-link-bg"></div>
            </a>
          </div>
        </div>
      </nav>
      <div class="menu-button w-nav-button"><img src="/images/menu-icon.svg" loading="lazy" alt="" class="menu-icon"></div>
    </div>
  </div>
  <div class="nav-line"></div>
</div>
