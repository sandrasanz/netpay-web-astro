# Netlify _redirects for netpayuk.com (Astro static build)
# Last updated: 19 May 2026 (Astro migration cutover)
# Docs: https://docs.netlify.com/routing/redirects/

# ============================================================
# Canonical domain enforcement (also handled by Netlify primary
# domain settings, but committed here as source of truth)
# ============================================================

http://netpayuk.com/*           https://netpayuk.com/:splat    301!
http://www.netpayuk.com/*       https://netpayuk.com/:splat    301!
https://www.netpayuk.com/*      https://netpayuk.com/:splat    301!

# ============================================================
# Kill netpayuk.app — redirect everything to .com
# (only active if netpayuk.app is added as a Netlify domain alias)
# ============================================================

https://netpayuk.app/*          https://netpayuk.com/:splat    301!
https://www.netpayuk.app/*      https://netpayuk.com/:splat    301!
http://netpayuk.app/*           https://netpayuk.com/:splat    301!
http://www.netpayuk.app/*       https://netpayuk.com/:splat    301!

# ============================================================
# Legacy .html URLs → clean Astro URLs
# Preserves SEO link equity from URLs Google has already indexed.
# ============================================================

/index.html                     /                              301!
/sales.html                     /sales                         301!
/features.html                  /features                      301!
/freelancers.html               /freelancers                   301!
/company.html                   /company                       301!
/contact.html                   /contact                       301!
/privacy.html                   /privacy                       301!
/terms.html                     /terms                         301!
/insights.html                  /insights                      301!
/android-beta.html              /android-beta                  301!
/delete-account.html            /delete-account                301!

# Consolidate duplicate privacy page (was /privacy-policy.html on old site)
/privacy-policy.html            /privacy                       301!

# Common alias
/about                          /company                       301
